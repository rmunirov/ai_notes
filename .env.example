# Database (async driver URL for SQLAlchemy)
DB_URL=postgresql+asyncpg://ai_notes:ai_notes@127.0.0.1:5432/ai_notes

# LangGraph / checkpoints (sync URL — replace +asyncpg with nothing)
CHECKPOINT_URL=postgresql://ai_notes:ai_notes@127.0.0.1:5432/ai_notes

# LLM (OpenAI-compatible; no hard-coded hostnames in app code)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-replace-me
LLM_MODEL=gpt-4o-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_EMBEDDING_DIMENSIONS=1536
LLM_TIMEOUT=30.0

# App
DEBUG=false
# Windows: uvicorn --reload can orphan the worker and leave PORT busy after Ctrl+C.
# Set to 1 only when you need auto-reload (otherwise leave unset / 0).
# UVICORN_RELOAD=1
# 0 = pick free port; fixed port recommended for local dev
PORT=8765
# When false, /search and /agent/* return 503 (graceful when no API key)
LLM_ENABLED=true
